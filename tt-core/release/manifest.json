{
  "product": "TT-Core",
  "bundle": "TT-Production-v14.0",
  "version": "v14.0",
  "build_date": "2026-03-14",
  "channel": "stable-commercial",
  "notes": "v14.0 — GA Fully Hardened Commercial Release. All 20 P0/P1 defects from v13.x series resolved. SOPS active, n8n-worker smoke-test, n8n workflow backup, all script banners v14.0.",
  "components": {
    "compose": "compose/tt-core/docker-compose.yml",
    "tunnel": "compose/tt-tunnel/docker-compose.yml",
    "installer": "installer/Install-TTCore.ps1",
    "installer_linux": "installer/Install-TTCore.sh",
    "env_template": "env/.env.example",
    "tunnel_env_template": "env/tunnel.env.example",
    "services_cfg": "config/services.select.json",
    "service_catalog": "config/service-catalog.json",
    "public_exposure_policy": "config/public-exposure.policy.json",
    "security_ack": "config/security-ack.json",
    "preflight": "scripts/Preflight-Check.ps1",
    "preflight_linux": "scripts-linux/preflight-check.sh",
    "smoke_test": "scripts-linux/smoke-test.sh",
    "backup": "scripts-linux/backup.sh",
    "restore": "scripts-linux/restore.sh",
    "init": "scripts-linux/init.sh",
    "start": "scripts-linux/start-core.sh",
    "start_alias": "scripts-linux/start.sh",
    "migrate_sops": "scripts-linux/migrate-to-sops.sh",
    "validate_sops": "scripts-linux/validate-sops.sh",
    "tunnel_plan": "scripts/Show-TunnelPlan.ps1",
    "unified_cli": "scripts/ttcore.ps1",
    "unified_cli_linux": "scripts-linux/ttcore.sh",
    "credential_rotation": "docs/CREDENTIAL_ROTATION.md",
    "dr_playbook": "docs/DR_PLAYBOOK.md",
    "sops_guide": "docs/SOPS_GUIDE.md"
  },
  "images": {
    "postgres": "postgres:16.6-alpine",
    "redis": "redis:7.4-alpine",
    "n8n": "n8nio/n8n:1.88.0",
    "pgadmin": "dpage/pgadmin4:8.14",
    "redisinsight": "redis/redisinsight:2.66",
    "metabase": "metabase/metabase:v0.52.9",
    "qdrant": "qdrant/qdrant:v1.13.4",
    "ollama": "ollama/ollama:0.6.5",
    "cloudflared": "cloudflare/cloudflared:2025.2.1",
    "wordpress": "wordpress:6.7.2-php8.3-apache",
    "mariadb": "mariadb:11.3",
    "kanboard": "kanboard/kanboard:v1.2.44",
    "uptime-kuma": "louislam/uptime-kuma:1.23.16-debian",
    "portainer": "portainer/portainer-ce:2.21.5",
    "openwebui": "ghcr.io/open-webui/open-webui:v0.5.20",
    "openclaw": "built-from-source (pinned to node:22.14.0-bookworm)"
  },
  "requires": {
    "docker": ">=24.0",
    "compose": ">=2.20",
    "powershell_windows": ">=5.1",
    "pwsh_linux": ">=7.0"
  },
  "security": {
    "secret_mode": "SOPS+age encrypted (plaintext fallback available)",
    "redis_auth": true,
    "redis_persistence": "AOF-only",
    "qdrant_api_key": true,
    "db_isolation": true,
    "bind_ip": "127.0.0.1",
    "log_rotation": "50m x 3 files — all services",
    "memory_limits": "all services have deploy.resources limits",
    "n8n_execution_mode": "queue (Redis-backed)",
    "tunnel_runtime": "token-only",
    "sops_encryption": true,
    "restricted_admin_requires_ack": true
  },
  "release_date": "2026-03-14"
}
