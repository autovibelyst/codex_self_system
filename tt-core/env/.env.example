# =============================================================================
# TT-Core — Source Environment Template (tt-core/env/.env.example)
# Version: TT-Production v14.0
#
# AUTHORITY MODEL:
#   THIS IS THE SOURCE TEMPLATE. Edit here, then run:
#     bash scripts-linux/init.sh      (Linux/macOS)
#     scripts\Init-TTCore.ps1         (Windows)
#   Init copies this to the external runtime env, filling __GENERATE__ slots.
#   SAFE TO RE-RUN: Init never overwrites existing real values.
# =============================================================================

TT_TZ=__CLIENT_TIMEZONE__
TT_BIND_IP=127.0.0.1

TT_POSTGRES_USER=ttcore
TT_POSTGRES_PASSWORD=__GENERATE__
TT_POSTGRES_DB=ttcore
TT_POSTGRES_HOST_PORT=15432
TT_PG_SHARED_BUFFERS=256MB
TT_PG_MAX_CONNECTIONS=200
TT_PG_WORK_MEM=4MB

TT_N8N_DB=n8n
TT_N8N_DB_USER=n8n
TT_N8N_DB_PASSWORD=__GENERATE__

TT_METABASE_DB=metabase_db
TT_METABASE_DB_USER=metabase
TT_METABASE_DB_PASSWORD=__GENERATE__

TT_KANBOARD_DB=kanboard_db
TT_KANBOARD_DB_USER=kanboard
TT_KANBOARD_DB_PASSWORD=__GENERATE__

TT_REDIS_PASSWORD=__GENERATE__
TT_REDIS_HOST_PORT=16379
TT_REDISINSIGHT_HOST_PORT=15540
TT_REDISINSIGHT_PASSWORD=__GENERATE__

TT_N8N_HOST=127.0.0.1
TT_N8N_HOST_PORT=15678
TT_N8N_PROTOCOL=http
TT_N8N_WEBHOOK_URL=http://127.0.0.1:15678/
TT_N8N_EDITOR_BASE_URL=http://127.0.0.1:15678
TT_N8N_EXECUTIONS_MODE=queue
TT_N8N_ENCRYPTION_KEY=__GENERATE__

TT_PGADMIN_EMAIL=admin@example.local
TT_PGADMIN_PASSWORD=__GENERATE__
TT_PGADMIN_HOST_PORT=15050

TT_METABASE_HOST_PORT=13010
TT_WORDPRESS_HOST_PORT=18081
TT_MARIADB_HOST_PORT=13306
TT_WP_DB_NAME=wordpress
TT_WP_DB_USER=wordpress
TT_WP_DB_PASSWORD=__GENERATE__
TT_WP_ROOT_PASSWORD=__GENERATE__
TT_KANBOARD_HOST_PORT=18082
TT_KANBOARD_ADMIN_PASSWORD=__GENERATE__
TT_UPTIME_KUMA_HOST_PORT=13001
TT_PORTAINER_HOST_PORT=19000
TT_QDRANT_API_KEY=__GENERATE__
TT_QDRANT_HOST_PORT=16333
TT_QDRANT_GRPC_PORT=16334
TT_OLLAMA_HOST_PORT=11434
TT_OPENWEBUI_HOST_PORT=13002
TT_OPENCLAW_HOST_PORT=18789
TT_OPENCLAW_MODE=setup
TT_OPENCLAW_MODEL=ollama/llama3.2
TT_OPENCLAW_SOURCE_REF=__PIN_GIT_TAG_OR_COMMIT__
TT_OPENCLAW_TOKEN=__GENERATE__
# SMTP — Leave TT_SMTP_HOST empty to disable. All vars are optional.
TT_SMTP_HOST=
TT_SMTP_PORT=587
TT_SMTP_USER=
TT_SMTP_PASSWORD=
TT_SMTP_FROM=noreply@example.local
TT_SMTP_SECURE=false

TT_BACKUP_NOTIFY_WEBHOOK_URL=
TT_MONITOR_NOTIFY_WEBHOOK_URL=
TT_MONITOR_DISK_WARN_THRESHOLD=80
TT_MONITOR_MEM_WARN_THRESHOLD=85

# ── Secret Mode ───────────────────────────────────────────────────────────────
# TT_SECRET_MODE=sops     # default — use SOPS+age encrypted secrets
# TT_SECRET_MODE=plaintext # fallback — plaintext .env (not recommended for production)

# ── MinIO ────────────────────────────────────────────────────────────────────
TT_MINIO_USER=minioadmin
TT_MINIO_PASSWORD=__GENERATE__

# ── Grafana Monitoring ───────────────────────────────────────────────────────
TT_GRAFANA_PASSWORD=__GENERATE__
TT_GRAFANA_URL=http://localhost:3001

# ── Qdrant (moved to addon) ──────────────────────────────────────────────────
TT_QDRANT_API_KEY=__GENERATE__

# ══════════════════════════════════════════════════════════════════════════════
# SECTION 11: N8N API KEY (for workflow backup)
# ══════════════════════════════════════════════════════════════════════════════
# Generate in n8n UI: Settings → API → Create API Key
# Required by backup.sh to auto-export workflow definitions.
# Leave empty to skip n8n workflow backup (not recommended for production).
TT_N8N_API_KEY=
