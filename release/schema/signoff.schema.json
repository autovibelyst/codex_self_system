{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "tt-signoff/v1",
  "title": "TT-Production Release Signoff",
  "type": "object",
  "required": ["_schema","generated_at","tt_version","verdict","export_allowed","stages"],
  "properties": {
    "_schema":        { "type": "string", "const": "tt-signoff/v1" },
    "_generator":     { "type": "string" },
    "generated_at":   { "type": "string", "format": "date-time" },
    "tt_version":     { "type": "string" },
    "verdict":        { "type": "string", "enum": ["PASS","PASS_WITH_NOTES","FAIL","BLOCKED"] },
    "export_allowed": { "type": "boolean" },
    "handoff_allowed":{ "type": "boolean" },
    "stages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["stage_id","stage_name","result","exit_code"],
        "properties": {
          "stage_id":     { "type": "integer" },
          "stage_name":   { "type": "string" },
          "result":       { "type": "string", "enum": ["PASS","FAIL","BLOCKED","SKIPPED","WARN"] },
          "exit_code":    { "type": "integer" },
          "duration_ms":  { "type": "integer" },
          "message":      { "type": ["string","null"] },
          "evidence_file":{ "type": ["string","null"] }
        }
      }
    },
    "notes":    { "type": "array", "items": { "type": "string" } },
    "blockers": { "type": "array", "items": { "type": "string" } }
  }
}
