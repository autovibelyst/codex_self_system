# =============================================================================
# TT-Supabase Environment Template  (TT-Production v14.0)
# Version: v14.0
#
# Source of truth for all tt-supabase service configuration.
# Copy target: compose/tt-supabase/.env
#
# REQUIRED STEPS:
#   1. Copy this file to compose/tt-supabase/.env
#   2. Replace ALL __GENERATE__ values with strong random secrets (32+ chars)
#      OR run: scripts\Init-Supabase.ps1 (auto-generates all secrets)
#   3. Replace ALL __SET__ values with your real configuration
#   4. Run Preflight: scripts\Preflight-Check.ps1 -IncludeSupabase
#
# SECURITY:
#   - NEVER commit .env to version control
#   - JWT_SECRET must be at least 32 characters and never reused
#   - ANON_KEY / SERVICE_ROLE_KEY are JWTs signed with JWT_SECRET
#     (Init-Supabase.ps1 generates correctly-signed tokens automatically)
# =============================================================================

# ── Project identity ──────────────────────────────────────────────────────────
# Used internally for Supabase Studio and log labeling.
STUDIO_DEFAULT_ORGANIZATION=__SET_YOUR_ORG_NAME__
STUDIO_DEFAULT_PROJECT=__SET_YOUR_PROJECT_NAME__

# ── Public URLs ───────────────────────────────────────────────────────────────
# The public URL clients use to reach the Supabase API (via Cloudflare Tunnel
# or reverse proxy pointing to Kong port 8000).
# Example: https://supabase.yourdomain.com
SUPABASE_PUBLIC_URL=https://__SET_YOUR_SUPABASE_DOMAIN__

# The URL GoTrue (auth) uses as the base for redirect links in emails.
# Usually the same as SUPABASE_PUBLIC_URL.
API_EXTERNAL_URL=https://__SET_YOUR_SUPABASE_DOMAIN__

# The site URL — your frontend application URL (used in auth email redirects).
# Example: https://app.yourdomain.com
SITE_URL=https://__SET_YOUR_APP_DOMAIN__

# ── Kong Gateway (only port published to host) ─────────────────────────────
# Bind to 127.0.0.1 for Cloudflare Tunnel deployments (recommended).
# Change to 0.0.0.0 only if Kong is behind a separate reverse proxy on the host.
KONG_HTTP_HOST=127.0.0.1
KONG_HTTP_PORT=18000
KONG_HTTPS_HOST=127.0.0.1
KONG_HTTPS_PORT=18443

# ── Studio Dashboard credentials ───────────────────────────────────────────
# These protect the Studio UI via Kong's basic-auth plugin.
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=__GENERATE__

# ── Supavisor Connection Pooler (optional profile) ──────────────────────────
POOLER_HOST=127.0.0.1
POOLER_PROXY_PORT_TRANSACTION=16543

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# POSTGRES_PASSWORD is shared across all internal Supabase service accounts.
# The supabase/postgres image creates dedicated roles using this password.
POSTGRES_PASSWORD=__GENERATE__
POSTGRES_DB=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ── JWT Secrets ───────────────────────────────────────────────────────────────
# JWT_SECRET: minimum 32 characters, cryptographically random.
# ANON_KEY + SERVICE_ROLE_KEY: JWTs signed with JWT_SECRET.
#   Auto-generated by Init-Supabase.ps1 with correct role claims.
#   If generating manually: role=anon (ANON_KEY), role=service_role (SERVICE_ROLE_KEY)
JWT_SECRET=__GENERATE__
JWT_EXPIRY=3600
ANON_KEY=__GENERATE__
SERVICE_ROLE_KEY=__GENERATE__

# ── Logflare / Analytics ──────────────────────────────────────────────────────
# Random API key used by the analytics service and Studio.
# Auto-generated by Init-Supabase.ps1.
LOGFLARE_API_KEY=__GENERATE__

# ── Auth (GoTrue) settings ────────────────────────────────────────────────────

# Disable public signup (true = only admin-invited users can register).
# Set to false to allow open registration.
DISABLE_SIGNUP=false

# Email authentication
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=false
ENABLE_ANONYMOUS_SIGN_INS=false

# Phone authentication (requires SMS provider config below)
ENABLE_PHONE_SIGNUP=false
ENABLE_PHONE_AUTOCONFIRM=false

# Auth email redirect paths (relative to API_EXTERNAL_URL)
MAILER_URLPATHS_INVITE=/auth/v1/verify
MAILER_URLPATHS_CONFIRMATION=/auth/v1/verify
MAILER_URLPATHS_RECOVERY=/auth/v1/verify
MAILER_URLPATHS_EMAIL_CHANGE=/auth/v1/verify

# Additional allowed OAuth redirect URLs (comma-separated)
# Example: https://app.yourdomain.com/callback,https://app.yourdomain.com/auth
ADDITIONAL_REDIRECT_URLS=

# ── SMTP (for auth emails) ────────────────────────────────────────────────────
# Leave empty to use Supabase's built-in inbucket (dev only, no real delivery).
# For production, configure a real SMTP provider (e.g. Resend, SendGrid, SES).
SMTP_ADMIN_EMAIL=noreply@__SET_YOUR_DOMAIN__
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_NAME=TT-Supabase

# ── PostgREST ─────────────────────────────────────────────────────────────────
# Comma-separated list of PostgreSQL schemas exposed via the REST API.
PGRST_DB_SCHEMAS=public,storage,graphql_public

# ── Edge Functions ────────────────────────────────────────────────────────────
# Whether to verify JWT on function invocation (true = require auth).
FUNCTIONS_VERIFY_JWT=false

# ── Image Proxy ───────────────────────────────────────────────────────────────
IMGPROXY_ENABLE_WEBP_DETECTION=true

