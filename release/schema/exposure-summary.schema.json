{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "tt-exposure-summary/v1",
  "title": "TT-Production Exposure Summary",
  "type": "object",
  "required": ["_schema","_generator","generated_at","tt_version","services"],
  "properties": {
    "_schema":      { "type": "string", "const": "tt-exposure-summary/v1" },
    "_generator":   { "type": "string" },
    "generated_at": { "type": "string", "format": "date-time" },
    "tt_version":   { "type": "string" },
    "services": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["service","tier","exposure_class","tunnel_enabled","requires_ack"],
        "properties": {
          "service":        { "type": "string" },
          "display_name":   { "type": "string" },
          "tier":           { "type": "string" },
          "exposure_class": { "type": "string" },
          "tunnel_enabled": { "type": "boolean" },
          "requires_ack":   { "type": "boolean" },
          "subdomain_var":  { "type": ["string","null"] }
        }
      }
    }
  }
}
